---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface ImageType {
  src: ImageMetadata;
  alt: string;
}

export interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  images: ImageType[];
}

const { title, subtitle, ctaText, ctaHref, images = [] } = Astro.props;

// Pick 6 images spread evenly across the collection
const count = 6;
const step = Math.max(1, Math.floor(images.length / count));
const selected = Array.from({ length: Math.min(count, images.length) }, (_, i) => images[i * step]);
---

<section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-6 gap-4 reveal-up">
    <div>
      <p class="text-sm font-medium tracking-[0.2em] uppercase text-gray-500 dark:text-accent mb-3">
        {subtitle}
      </p>
      <h2 class="text-3xl md:text-4xl font-bold font-heading leading-tight">
        {title}
      </h2>
    </div>
    <a href={ctaHref} class="portfolio-cta group">
      <span>{ctaText}</span>
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
        <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div class="bento-portfolio">
    {selected.map((image, index) => (
      <a
        href={ctaHref}
        class:list={[
          "bento-item",
          `bento-item-${index + 1}`,
          `reveal-up reveal-delay-${(index % 3) + 1}`,
        ]}
      >
        <Image
          src={image.src}
          alt={image.alt}
          widths={[320, 480, 640]}
          sizes="(min-width: 768px) 33vw, 50vw"
          format="avif"
          quality={75}
          loading="lazy"
          decoding="async"
          class="bento-img"
        />
        <div class="bento-overlay" aria-hidden="true"></div>
      </a>
    ))}
  </div>
</section>

<style>
  /* ===== Mobile: 2-column grid ===== */
  .bento-portfolio {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 160px;
    gap: 0.5rem;
  }

  .bento-item-1 {
    grid-column: span 2;
  }

  /* ===== Tablet & Desktop: 3-column flat grid ===== */
  @media (min-width: 768px) {
    .bento-portfolio {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 200px 200px;
      grid-auto-rows: unset;
      gap: 0.75rem;
    }

    .bento-item-1 {
      grid-column: span 1;
    }
  }

  /* ===== Item base ===== */
  .bento-item {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    display: block;
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bento-item:hover .bento-img {
    transform: scale(1.05);
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.35) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .bento-item:hover .bento-overlay {
    opacity: 1;
  }

  /* ===== CTA link ===== */
  .portfolio-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgb(184 132 72);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.3s ease;
  }

  .portfolio-cta:hover {
    opacity: 0.8;
  }
</style>
