---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { localizePath } from "astro-i18next";
import { t } from "i18next";

interface ImageType {
  src: ImageMetadata;
  alt: string;
}

interface Category {
  title: string;
  href: string;
}

interface Props {
  images: ImageType[];
  headline: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  categories?: Category[];
}

const {
  images = [],
  headline,
  subtitle,
  ctaText,
  ctaHref,
  categories = [],
} = Astro.props;
---

<section
  class="hero-section"
  data-hero-root
  aria-label={headline}
>
  {/* Background image layers for crossfade */}
  <div class="hero-images" aria-hidden="true">
    {images.map((image, index) => (
      <Image
        src={image.src}
        alt=""
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
        format="avif"
        quality={80}
        class:list={["hero-bg-img", { active: index === 0 }]}
        data-hero-img={index}
        loading={index === 0 ? "eager" : "lazy"}
        decoding={index === 0 ? "sync" : "async"}
        fetchpriority={index === 0 ? "high" : undefined}
      />
    ))}
  </div>

  {/* Gradient overlays */}
  <div class="hero-overlay"></div>
  <div class="hero-grain"></div>

  {/* Main content */}
  <div class="hero-content">
    <div class="hero-eyebrow" data-hero-animate="eyebrow">
      <span class="hero-eyebrow-line"></span>
      <span class="hero-eyebrow-text">The Kitchen Studio</span>
      <span class="hero-eyebrow-line"></span>
    </div>

    <h1 class="hero-headline" data-hero-animate="headline">
      {headline}
    </h1>

    <p class="hero-subtitle" data-hero-animate="subtitle">
      {subtitle}
    </p>

    <a
      href={ctaHref}
      class="hero-cta"
      data-hero-animate="cta"
    >
      <span>{ctaText}</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    {categories.length > 0 && (
      <nav class="hero-categories" data-hero-animate="categories" aria-label="Product categories">
        {categories.map((cat) => (
          <a href={cat.href} class="hero-category-pill">
            {cat.title}
          </a>
        ))}
      </nav>
    )}
  </div>

  {/* Image counter */}
  <div class="hero-counter" data-hero-animate="counter" aria-live="polite">
    <span class="hero-counter-current" data-hero-counter-current>01</span>
    <span class="hero-counter-sep">/</span>
    <span class="hero-counter-total">{String(images.length).padStart(2, "0")}</span>
  </div>

  {/* Progress bar */}
  <div class="hero-progress" aria-hidden="true">
    <div class="hero-progress-track">
      <div class="hero-progress-bar" data-hero-progress></div>
    </div>
  </div>

  {/* Scroll indicator */}
  <div class="hero-scroll" data-hero-animate="scroll" aria-hidden="true">
    <span class="hero-scroll-text">Scroll</span>
    <div class="hero-scroll-line">
      <div class="hero-scroll-dot"></div>
    </div>
  </div>
</section>

<style>
  /* ===== Hero Section ===== */
  .hero-section {
    position: relative;
    width: 100%;
    height: calc(100svh - var(--header-height, 100px));
    min-height: 600px;
    overflow: hidden;
    background: #0a0a0a;
  }

  /* ===== Background Images ===== */
  .hero-images {
    position: absolute;
    inset: 0;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    scale: 1.05;
    transition: opacity 1.6s cubic-bezier(0.4, 0, 0.2, 1), scale 8s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity, scale;
  }

  .hero-bg-img.active {
    opacity: 1;
    scale: 1;
  }

  /* ===== Overlays ===== */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.05) 30%,
        rgba(0, 0, 0, 0.2) 60%,
        rgba(0, 0, 0, 0.7) 100%
      ),
      linear-gradient(90deg,
        rgba(0, 0, 0, 0.4) 0%,
        rgba(0, 0, 0, 0) 50%
      );
    z-index: 1;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.03;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* ===== Content ===== */
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    height: 100%;
    padding: 2rem 1.5rem 8rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: 4rem 3rem 7rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: 4rem 4rem 6rem;
      justify-content: center;
      padding-bottom: 4rem;
    }
  }

  /* ===== Eyebrow ===== */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-eyebrow-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: rgb(184 132 72);
  }

  .hero-eyebrow-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgb(184 132 72);
  }

  @media (min-width: 768px) {
    .hero-eyebrow {
      margin-bottom: 2rem;
    }
    .hero-eyebrow-line {
      width: 3rem;
    }
    .hero-eyebrow-text {
      font-size: 0.85rem;
    }
  }

  /* ===== Headline ===== */
  .hero-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.2rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    max-width: 14ch;
    margin: 0 0 1.5rem;
    opacity: 0;
    transform: translateY(40px);
  }

  @media (min-width: 768px) {
    .hero-headline {
      margin-bottom: 2rem;
    }
  }

  /* ===== Subtitle ===== */
  .hero-subtitle {
    font-family: var(--aw-font-sans), system-ui, sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    max-width: 42ch;
    margin: 0 0 2rem;
    opacity: 0;
    transform: translateY(30px);
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      margin-bottom: 2.5rem;
    }
  }

  /* ===== CTA Button ===== */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 2rem;
    border: 1px solid rgba(184, 132, 72, 0.6);
    color: rgb(184 132 72);
    font-family: var(--aw-font-sans), system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(184 132 72);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }

  .hero-cta:hover {
    color: #fff;
    border-color: rgb(184 132 72);
  }

  .hero-cta:hover::before {
    transform: scaleX(1);
  }

  .hero-cta svg {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-cta:hover svg {
    transform: translateX(4px);
  }

  /* ===== Category Pills ===== */
  .hero-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    opacity: 0;
    transform: translateY(20px);
  }

  @media (min-width: 768px) {
    .hero-categories {
      margin-top: 3rem;
      gap: 0.625rem;
    }
  }

  .hero-category-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.125rem;
    min-height: 44px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--aw-font-sans), system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .hero-category-pill:hover {
    background: rgba(184, 132, 72, 0.15);
    border-color: rgba(184, 132, 72, 0.4);
    color: rgb(184 132 72);
  }

  /* ===== Counter ===== */
  .hero-counter {
    position: absolute;
    right: 1.5rem;
    bottom: 7rem;
    z-index: 10;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    opacity: 0;
  }

  @media (min-width: 768px) {
    .hero-counter {
      right: 3rem;
      bottom: 5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-counter {
      right: 4rem;
      bottom: 4rem;
    }
  }

  .hero-counter-current {
    font-size: 2.5rem;
    font-weight: 300;
    color: #fff;
    line-height: 1;
    transition: opacity 0.3s;
  }

  .hero-counter-sep {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0 0.15rem;
  }

  .hero-counter-total {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.4);
  }

  /* ===== Progress Bar ===== */
  .hero-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-progress {
      padding: 0 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-progress {
      padding: 0 4rem;
    }
  }

  .hero-progress-track {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  .hero-progress-bar {
    height: 100%;
    width: 0%;
    background: rgb(184 132 72);
    transition: width 0.1s linear;
  }

  /* ===== Scroll Indicator ===== */
  .hero-scroll {
    position: absolute;
    left: 1.5rem;
    bottom: 2.5rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
  }

  @media (min-width: 768px) {
    .hero-scroll {
      left: 3rem;
      bottom: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-scroll {
      left: 4rem;
      bottom: 1.5rem;
    }
  }

  .hero-scroll-text {
    font-family: var(--aw-font-sans), system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    display: none;
  }

  @media (min-width: 768px) {
    .hero-scroll-text {
      display: block;
    }
  }

  .hero-scroll-line {
    width: 1px;
    height: 3rem;
    background: rgba(255, 255, 255, 0.15);
    position: relative;
    overflow: hidden;
  }

  .hero-scroll-dot {
    width: 1px;
    height: 1rem;
    background: rgb(184 132 72);
    position: absolute;
    top: -1rem;
    animation: scrollPulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes scrollPulse {
    0% {
      top: -1rem;
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    100% {
      top: 3rem;
      opacity: 0;
    }
  }

  /* ===== Animations ===== */
  .hero-animate-in {
    opacity: 1 !important;
    transform: translateY(0) !important;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1), transform 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-bg-img {
      transition: opacity 0.5s ease;
      scale: 1 !important;
    }

    .hero-scroll-dot {
      animation: none;
    }

    [data-hero-animate] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initHero() {
    const root = document.querySelector('[data-hero-root]');
    if (!root) return;

    const images = root.querySelectorAll<HTMLImageElement>('[data-hero-img]');
    const progressBar = root.querySelector<HTMLElement>('[data-hero-progress]');
    const counterCurrent = root.querySelector<HTMLElement>('[data-hero-counter-current]');
    const animatedEls = root.querySelectorAll<HTMLElement>('[data-hero-animate]');

    if (images.length === 0) return;

    const INTERVAL = 6000;
    const PROGRESS_TICK = 50;
    let currentIndex = 0;
    let progressValue = 0;
    let progressTimer: ReturnType<typeof setInterval> | null = null;
    let slideTimer: ReturnType<typeof setTimeout> | null = null;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Entrance animations with staggered delays
    const staggerDelays: Record<string, number> = {
      eyebrow: 300,
      headline: 500,
      subtitle: 700,
      cta: 900,
      categories: 1100,
      counter: 800,
      scroll: 1300,
    };

    function animateIn() {
      animatedEls.forEach((el) => {
        const key = el.dataset.heroAnimate || '';
        const delay = staggerDelays[key] || 500;
        setTimeout(() => {
          el.classList.add('hero-animate-in');
        }, delay);
      });
    }

    function goToSlide(index: number) {
      images.forEach((img) => img.classList.remove('active'));
      images[index]?.classList.add('active');

      if (counterCurrent) {
        counterCurrent.style.opacity = '0';
        setTimeout(() => {
          counterCurrent.textContent = String(index + 1).padStart(2, '0');
          counterCurrent.style.opacity = '1';
        }, 200);
      }
    }

    function startProgress() {
      progressValue = 0;
      if (progressBar) progressBar.style.width = '0%';

      progressTimer = setInterval(() => {
        progressValue += PROGRESS_TICK;
        const pct = Math.min((progressValue / INTERVAL) * 100, 100);
        if (progressBar) progressBar.style.width = `${pct}%`;
      }, PROGRESS_TICK);
    }

    function nextSlide() {
      if (progressTimer) clearInterval(progressTimer);
      currentIndex = (currentIndex + 1) % images.length;
      goToSlide(currentIndex);
      startProgress();
      slideTimer = setTimeout(nextSlide, INTERVAL);
    }

    function startAutoplay() {
      startProgress();
      slideTimer = setTimeout(nextSlide, INTERVAL);
    }

    function stopAutoplay() {
      if (slideTimer) clearTimeout(slideTimer);
      if (progressTimer) clearInterval(progressTimer);
    }

    // Start
    if (prefersReducedMotion) {
      animatedEls.forEach((el) => el.classList.add('hero-animate-in'));
    } else {
      animateIn();
    }

    if (images.length > 1) {
      startAutoplay();
    }

    // Pause on tab hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoplay();
      } else if (images.length > 1) {
        startAutoplay();
      }
    });

    // Cleanup for Astro page transitions
    const cleanup = () => {
      stopAutoplay();
    };

    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }

  // Run on initial load and Astro page transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
  document.addEventListener('astro:page-load', initHero);
</script>
